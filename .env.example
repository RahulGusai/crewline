# Database
DATABASE_URL=postgresql+asyncpg://crewline:crewline@localhost:5432/crewline

# Application
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# CORS - comma-separated origins, used during dev for the frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Cookie behavior
# Local dev: HTTP, same-origin via Vite proxy
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Production (HTTPS, cross-origin):
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

SESSION_LIFETIME_HOURS=24
COOKIE_NAME=crewline_session

# Initial credentials (used once by migrations, then can be removed)
PM_INITIAL_PASSWORD=changeme
AGENT_BE_INITIAL_KEY=agent_be_devkey_replace_in_prod
AGENT_FE_INITIAL_KEY=agent_fe_devkey_replace_in_prod
AGENT_ARCHITECT_INITIAL_KEY=agent_architect_devkey_replace_in_prod
AGENT_QA_INITIAL_KEY=agent_qa_devkey_replace_in_prod

# Storage (local MinIO defaults)
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=crewline-attachments
STORAGE_REGION=us-east-1
STORAGE_ADDRESSING_STYLE=path

# Production (Railway Buckets)
# STORAGE_ENDPOINT_URL=https://storage.railway.app
# STORAGE_ACCESS_KEY=<from Railway>
# STORAGE_SECRET_KEY=<from Railway>
# STORAGE_BUCKET=<bucket name from Railway>
# STORAGE_ADDRESSING_STYLE=virtual

ATTACHMENT_MAX_SIZE_BYTES=26214400
ATTACHMENT_UPLOAD_URL_TTL_SECONDS=900
ATTACHMENT_DOWNLOAD_URL_TTL_SECONDS=900
ATTACHMENT_PENDING_CLEANUP_AGE_HOURS=24

# GitHub App integration
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=Crewline
GITHUB_FRONTEND_REDIRECT_URL=http://localhost:5173/settings?github=connected
